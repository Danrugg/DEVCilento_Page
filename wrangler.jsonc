{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dev-cilento-page",
  "compatibility_date": "2024-04-05",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "pages_build_output_dir": ".open-next/cloudflare-pages",
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "dev-cilento-page"
    }
  ]
}
